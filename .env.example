# Root environment template used by local tooling, Docker Compose, backups, and production deployments.
# Copy this file to .env and replace every CHANGE_ME value before deploying.

NODE_ENV=production

API_PORT=4000
API_PREFIX=api/v1

POSTGRES_DB=amg_academy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/amg_academy

REDIS_URL=redis://redis:6379

JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_REFRESH_SECRET_MINIMUM_32_CHARACTERS
JWT_RESET_SECRET=CHANGE_ME_RANDOM_RESET_SECRET_MINIMUM_32_CHARACTERS

FRONTEND_URL=https://CHANGE_ME_WEB_DOMAIN
API_URL=https://CHANGE_ME_API_DOMAIN/api/v1
NEXT_PUBLIC_API_URL=https://CHANGE_ME_API_DOMAIN/api/v1

GOOGLE_OAUTH_WEB_CLIENT_ID=CHANGE_ME_GOOGLE_WEB_CLIENT_ID
GOOGLE_OAUTH_ANDROID_CLIENT_ID=CHANGE_ME_GOOGLE_ANDROID_CLIENT_ID
GOOGLE_OAUTH_IOS_CLIENT_ID=

RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
RESEND_FROM_EMAIL="AMG Academy <no-reply@CHANGE_ME_DOMAIN>"

UPLOAD_DIR=./uploads
QR_TICKET_GRACE_MINUTES=120

VIDEO_STORAGE_PROVIDER=google-drive
GOOGLE_DRIVE_COURSE_VIDEOS_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.file,https://www.googleapis.com/auth/drive.readonly
