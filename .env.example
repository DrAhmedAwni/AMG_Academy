# Root environment template used by local tooling, Docker Compose, backups, and production PM2 deployments.

# Database
POSTGRES_DB=amg_academy_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amg_academy_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-with-a-secure-random-string-minimum-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-secure-random-refresh-string-minimum-32-chars
JWT_RESET_SECRET=replace-with-a-secure-random-reset-string-minimum-32-chars

# Email
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Uploads
UPLOAD_DIR=./uploads
