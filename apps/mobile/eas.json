{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "local",
        "EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS": "true",
        "EXPO_PUBLIC_ENABLE_PUSH_PREP": "true"
      }
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://api.amg.bdigital-dental.site/api/v1",
        "EXPO_PUBLIC_WEB_URL": "https://amg.bdigital-dental.site",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "664945461418-ucjd14j0jsmrmkanupf7qnio7s8jceos.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "664945461418-qtrpsbc534ct2fvgo72tdfgg51kbvuao.apps.googleusercontent.com",
    
        "EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS": "true",
        "EXPO_PUBLIC_ENABLE_PUSH_PREP": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.amg.bdigital-dental.site/api/v1",
        "EXPO_PUBLIC_WEB_URL": "https://amg.bdigital-dental.site",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "664945461418-ucjd14j0jsmrmkanupf7qnio7s8jceos.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "664945461418-qtrpsbc534ct2fvgo72tdfgg51kbvuao.apps.googleusercontent.com",
        
        "EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS": "false",
        "EXPO_PUBLIC_ENABLE_PUSH_PREP": "true"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.amg.bdigital-dental.site/api/v1",
        "EXPO_PUBLIC_WEB_URL": "https://amg.bdigital-dental.site",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "664945461418-ucjd14j0jsmrmkanupf7qnio7s8jceos.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "664945461418-qtrpsbc534ct2fvgo72tdfgg51kbvuao.apps.googleusercontent.com",
        
        "EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS": "false",
        "EXPO_PUBLIC_ENABLE_PUSH_PREP": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
