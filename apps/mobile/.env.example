# AMG Academy Mobile App V2 environment
#
# Copy this file to one of:
# - .env.local
# - .env.staging
# - .env.production
#
# Do not put private secrets in EXPO_PUBLIC_* values. These values are bundled
# into the mobile app.

# local | staging | production
EXPO_PUBLIC_APP_ENV=local

# Local backend from a physical Android device must use your computer LAN IP,
# for example http://192.168.1.6:4000/api/v1.
# Android emulator can use http://10.0.2.2:4000/api/v1.
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_WEB_URL=http://localhost:3000
# Public OAuth client IDs are bundled into the app; do not put private secrets here.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Mock payments are allowed for local/staging only.
EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS=true

# Push notification preparation can be enabled before production delivery.
EXPO_PUBLIC_ENABLE_PUSH_PREP=true

# Staging example:
# EXPO_PUBLIC_APP_ENV=staging
# EXPO_PUBLIC_API_URL=https://staging.amgacademy.com/api/v1
# EXPO_PUBLIC_WEB_URL=https://staging.amgacademy.com
# EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS=true
# EXPO_PUBLIC_ENABLE_PUSH_PREP=true

# Production example:
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_API_URL=https://amgacademy.com/api/v1
# EXPO_PUBLIC_WEB_URL=https://amgacademy.com
# EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS=false
# EXPO_PUBLIC_ENABLE_PUSH_PREP=true
