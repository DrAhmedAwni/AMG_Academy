{
  "expo": {
    "name": "AMG Academy",
    "slug": "amg-academy-mobile",
    "scheme": [
      "amgacademy",
      "com.amgacademy.mobile"
    ],
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amgacademy.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "AMG Academy uses the camera so authorized scanner staff can validate event QR tickets.",
        "NSUserNotificationsUsageDescription": "AMG Academy can send event, course, ticket, and announcement updates.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.amgacademy.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#111111",
          "dark": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#111111"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AMG Academy uses the camera so authorized scanner staff can validate event QR tickets."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4AF37"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "appEnv": "$EXPO_PUBLIC_APP_ENV",
      "apiUrl": "$EXPO_PUBLIC_API_URL",
      "webUrl": "$EXPO_PUBLIC_WEB_URL",
      "router": {},
      "eas": {
        "projectId": "9d40f591-7a2f-4bbf-b343-d503f447abb9"
      }
    }
  }
}
