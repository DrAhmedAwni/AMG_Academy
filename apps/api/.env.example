NODE_ENV=development
API_PORT=4000
API_PREFIX=api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amg_academy_dev
REDIS_URL=redis://localhost:6379

# JWT secrets MUST be at least 32 characters long.
# The application will refuse to start if they are shorter.
JWT_SECRET=replace-with-a-secure-random-string-minimum-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-secure-random-refresh-string-min-32-chars
JWT_RESET_SECRET=replace-with-a-secure-random-reset-string-minimum-32-chars

FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=./uploads
QR_TICKET_GRACE_MINUTES=120

# Course video storage. Use google_drive first for production course videos,
# while keeping vps/local upload storage available for local development or later migration.
VIDEO_STORAGE_PROVIDER=vps
GOOGLE_DRIVE_COURSE_VIDEOS_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=

RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
